{
  "name": "dynoxide-wasm",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "JS bridge and build for the dynoxide wasm-sqlite backend (preview). Bundles the wa-sqlite glue and the wasm-bindgen Worker into a self-contained dist/.",
